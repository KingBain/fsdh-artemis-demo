{
  "datasets": [
    {
      "name": "44ef0b83",
      "displayName": "Orion Velocity Trends Over Time Analysis Dataset",
      "queryLines": [
        "SELECT *\n",
        "FROM fsdh_artemis.vw_orion_speed_over_time\n",
        "ORDER BY epoch_utc"
      ]
    },
    {
      "name": "fbe3ae19",
      "displayName": "Orion Distance Tracking Over Time View",
      "queryLines": [
        "SELECT *\n",
        "FROM fsdh_artemis.vw_orion_distance_over_time\n",
        "ORDER BY epoch_utc"
      ]
    },
    {
      "name": "2f314f21",
      "displayName": "Latest Orion Timestamp",
      "queryLines": [
        "SELECT\n",
        "  latest_epoch_utc\n",
        "FROM fsdh_artemis.vw_orion_latest_kpis"
      ]
    },
    {
      "name": "2f708336",
      "displayName": "Latest Orion Speed",
      "queryLines": [
        "SELECT\n",
        "  speed_km_s\n",
        "FROM fsdh_artemis.vw_orion_latest_kpis"
      ]
    },
    {
      "name": "speed_vs_distance",
      "displayName": "Orion Speed vs Distance Over Time",
      "queryLines": [
        "SELECT\n",
        "  s.epoch_utc,\n",
        "  s.mission_elapsed_hours,\n",
        "  s.speed_km_s,\n",
        "  d.distance_from_origin_km\n",
        "FROM\n",
        "  fsdh_artemis.vw_orion_speed_over_time s\n",
        "    JOIN fsdh_artemis.vw_orion_distance_over_time d\n",
        "      ON s.epoch_utc = d.epoch_utc\n",
        "ORDER BY\n",
        "  s.epoch_utc"
      ]
    },
    {
      "name": "state_vector_count",
      "displayName": "Orion State Vector Count",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) AS state_vector_count\n",
        "FROM\n",
        "  fsdh_artemis.vw_orion_speed_over_time"
      ]
    }
  ],
